# Python virtual environment — never commit this
venv/
.venv/
env/
.env/
ENV/

# Compiled Python files
__pycache__/
*.py[cod]
*.pyo

# Environment variables — may contain secrets
.env
.env.*
!.env.example
.env.local
.env.*.local

# Secrets baseline is committed so it can be diffed, but not the audit log
.secrets.audit

# Test artifacts and coverage reports
.pytest_cache/
.coverage
htmlcov/
coverage.xml
.tox/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# macOS system files
.DS_Store
.AppleDouble
.LSOverride
._*

# Editor and IDE files
.idea/
.vscode/
*.swp
*.swo

# Logs and Temp Files
*.log
logs/
*.tmp
*.temp

# Mypy / type checking
.mypy_cache/
.dmypy.json

# Jupyter Notebooks
.ipynb_checkpoints/
